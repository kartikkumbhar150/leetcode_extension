{
  "manifest_version": 3,
  "name": "LeetSync — Auto GitHub Commit & Revision",
  "version": "1.0.0",
  "description": "Auto-commit accepted LeetCode solutions to GitHub with spaced repetition revision, analytics dashboards, and AI-powered review.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "identity",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://api.github.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["dashboard.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "oauth2": {
    "client_id": "YOUR_GITHUB_OAUTH_APP_CLIENT_ID",
    "scopes": ["repo", "user:email"]
  }
}
